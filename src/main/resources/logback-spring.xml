<?xml version="1.0" encoding="UTF-8"?>
<!--
    Profile-aware logback config.

    - Default (no profile, or anything but `prod`): colored, human-readable
      console output. Matches Spring Boot's default look so the local dev
      experience is unchanged.

    - `prod` profile: JSON output via logstash-logback-encoder. One event
      per line, with @timestamp / level / logger_name / thread_name /
      message / mdc + a stack_trace field on errors. A log shipper can
      index this without a parser ruleset.

    MdcFilter (auth/MdcFilter.java) populates the MDC with userId +
    requestId on every request, so each log line carries the user context
    automatically — no explicit MDC.put() calls in app code.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>@timestamp</fieldName>
                        <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</pattern>
                    </timestamp>
                    <logLevel/>
                    <loggerName/>
                    <threadName/>
                    <message/>
                    <mdc/>
                    <stackTrace/>
                </providers>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
